# Example environment file for commit/reference.
# Use this file as a template and keep the real secrets in `env_api_evolution.env`.

# ==========================================
# EVOLUTION API (modo dev local)
# ==========================================
SERVER_NAME=evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://api:8080

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution_user:evolution_password@postgres:5432/evolution_api?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution

POSTGRES_DATABASE=evolution_api
POSTGRES_USERNAME=evolution_user
POSTGRES_PASSWORD=evolution_password

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379
CACHE_REDIS_PREFIX_KEY=evolution-cache
CACHE_REDIS_TTL=604800
CACHE_REDIS_SAVE_INSTANCES=true

AUTHENTICATION_API_KEY=CHANGE_ME_NOW

CORS_ORIGIN=*
CORS_METHODS=POST,GET,PUT,DELETE
CORS_CREDENTIALS=true

LOG_LEVEL=ERROR,WARN,DEBUG,INFO,LOG,VERBOSE,DARK,WEBHOOKS,WEBSOCKET
LOG_COLOR=true
LOG_BAILEYS=error

WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=true

# ==========================================
# INTEGRAÇÕES
# ==========================================

TYPEBOT_ENABLED=true
TYPEBOT_API_VERSION=old
TYPEBOT_SEND_MEDIA_BASE64=false

CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_DELETE=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_BOT_CONTACT=true
CHATWOOT_IMPORT_DATABASE_CONNECTION_URI=postgresql://chatwoot:chatwoot@chatwoot-postgres:5432/chatwoot_production?schema=public
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=false

OPENAI_ENABLED=true
OPENAI_API_KEY_GLOBAL=CHANGE_ME_NOW

DIFY_ENABLED=true
N8N_ENABLED=true
EVOAI_ENABLED=true
FLOWISE_ENABLED=true
